{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "platformAutomerge": true,
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "packageRules": [
    {
      "description": "Automerge all dependencies once CI passes",
      "matchPackageNames": ["*"],
      "automerge": true
    },
    {
      "description": "Never automerge major updates; review them manually",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
