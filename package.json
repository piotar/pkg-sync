{
    "name": "@piotar/pkg-sync",
    "version": "2.4.0",
    "description": "A utility for synchronization multiple packages, without any symlinks and any changes in projects(package.json, etc.).",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/piotar/pkg-sync.git"
    },
    "keywords": [
        "cli",
        "copy files",
        "copy projects",
        "sync packages",
        "synchronization packages",
        "watch files",
        "dev-tool"
    ],
    "author": "Piotr Tarasiuk",
    "license": "MIT",
    "type": "module",
    "bugs": {
        "url": "https://github.com/piotar/pkg-sync/issues"
    },
    "homepage": "https://github.com/piotar/pkg-sync",
    "module": "./dist/cli.js",
    "bin": {
        "pkg-sync": "./dist/cli.js"
    },
    "files": [
        "dist",
        "README.md",
        "SKILL.md",
        ".claude-plugin"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "pkg-sync": "bun run ./src/cli.ts",
        "build": "bun run ./scripts/build.ts",
        "start": "node ./dist/cli.js",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "lint": "eslint .",
        "changeset": "changeset",
        "version-packages": "changeset version && bun install",
        "release": "changeset publish",
        "prepublishOnly": "bun run build"
    },
    "devDependencies": {
        "@changesets/cli": "2.31.0",
        "@clack/prompts": "1.7.0",
        "@eslint/js": "10.0.1",
        "@tsconfig/bun": "1.0.10",
        "@types/bun": "1.3.14",
        "@types/node": "26.1.1",
        "@types/picomatch": "4.0.3",
        "citty": "0.2.2",
        "eslint": "10.6.0",
        "picomatch": "4.0.5",
        "typescript": "6.0.3",
        "typescript-eslint": "8.62.1"
    }
}
